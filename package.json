{
  "name": "roboiom3",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "biome format . --write",
    "format-and-lint": "biome check .",
    "format-and-lint:fix": "biome check . --write",
    "check-types": "turbo run check-types",
    "deps:update": "pnpm update -r -i",
    "deps:dedupe:check": "pnpm dedupe --check",
    "deps:dedupe": "pnpm dedupe",
    "deps:syncpack:check": "pnpm syncpack list-mismatches",
    "deps:syncpack:fix": "pnpm syncpack fix-mismatches",
    "deps:clear": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
    "ports": "lsof -i -P -n | grep LISTEN",
    "kill:port": "sh -c 'for arg in \"$@\"; do if [ \"$arg\" != \"--\" ]; then port=\"$arg\"; break; fi; done; if [ -z \"$port\" ]; then echo \"Usage: pnpm run kill:port -- <port>\"; exit 1; fi; pids=$(lsof -ti tcp:$port 2>/dev/null); if [ -z \"$pids\" ]; then echo \"No process on port $port\"; else echo \"Killing process(es) on port $port: $pids\"; kill $pids; fi' --",
    "quiz": "tsx scripts/quiz.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@repo/typescript-config": "workspace:*",
    "@total-typescript/ts-reset": "^0.6.1",
    "syncpack": "^13.0.4",
    "tsx": "^4.19.2",
    "turbo": "^2.5.8"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
