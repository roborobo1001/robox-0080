{
  "name": "roboiom3",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "biome format . --write",
    "format-and-lint": "biome check .",
    "format-and-lint:fix": "biome check . --write",
    "check-types": "turbo run check-types",
    "deps:update": "pnpm update -r -i",
    "deps:dedupe:check": "pnpm dedupe --check",
    "deps:dedupe": "pnpm dedupe",
    "deps:syncpack:check": "pnpm syncpack list-mismatches",
    "deps:syncpack:fix": "pnpm syncpack fix-mismatches",
    "deps:clear": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
    "ports": "lsof -i -P -n | grep LISTEN",
    "kill:port": "bash -lc 'port=${1:?Usage: pnpm run kill:port -- <port>}; pids=$(lsof -ti tcp:$port); if [ -z \"$pids\" ]; then echo \"No process on $port\"; else echo \"Killing: $pids\"; kill $pids; fi' --"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@repo/typescript-config": "workspace:*",
    "@total-typescript/ts-reset": "^0.6.1",
    "syncpack": "^13.0.4",
    "turbo": "^2.5.8"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
