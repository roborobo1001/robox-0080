{
  "name": "@repo/contracts",
  "type": "module",
  "version": "0.0.0",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup --config tsup.config.ts",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@repo/data": "workspace:*",
    "@ts-rest/core": "^3.52.1",
    "tsup": "^8.5.0",
    "typescript": "*",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "@ts-rest/core": "^3.52.1",
    "@repo/typescript-config": "workspace:*",
    "@repo/data": "workspace:*",
    "zod": "^3.23.8"
  }
}
